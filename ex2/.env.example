# Matrix Configuration Example

# "development" or "production"
MATRIX_MODE=development

# Connection string for data storage
DATABASE_URL=protocol:path/to/database/file.sqlite3

# Secret key for external services
API_KEY=

# Logging verbosity: FATAL/CRITICAL ERROR WARN INFO DEBUG TRACE
LOG_LEVEL=DEBUG

# URL for the resistance network
ZION_ENDPOINT=http://localhost:8000
